<mah:MetroWindow x:ClassModifier="internal"
        x:Class="Poe2LootLens.GeneralSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        FontFamily="{DynamicResource AppFontFamily}"
        Title="Настройки приложения"
        Width="620" Height="650"
        MinWidth="560" MinHeight="580"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="app.ico"
        WindowTitleBrush="#181D26"
        NonActiveWindowTitleBrush="#181D26"
        TitleForeground="#C5CEDA"
        GlowBrush="#303845"
        TitleCharacterCasing="Normal">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,12,0">
                <TextBlock x:Name="HeaderText" Text="Общие настройки" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="HeaderDescriptionText" Text="Интерфейс, язык клиента, рынок, обновление и диагностика."
                           Style="{StaticResource AppMutedText}" Margin="0,4,0,18"/>

                <Border Style="{StaticResource AppCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="LanguageSectionText" Text="Языки" Style="{StaticResource AppSectionTitle}"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="UiLanguageLabel" Text="Язык приложения" Style="{StaticResource AppLabel}"/>
                                <ComboBox x:Name="UiLanguageCombo" Style="{StaticResource AppComboBox}">
                                    <ComboBoxItem Tag="auto">Автоматически</ComboBoxItem>
                                    <ComboBoxItem Tag="ru">Русский</ComboBoxItem>
                                    <ComboBoxItem Tag="en">English</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="GameLanguageLabel" Text="Язык клиента POE2" Style="{StaticResource AppLabel}"/>
                                <ComboBox x:Name="GameLanguageCombo" Style="{StaticResource AppComboBox}">
                                    <ComboBoxItem Tag="ru">Русский</ComboBoxItem>
                                    <ComboBoxItem Tag="en">English</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock x:Name="RumorLanguageLabel" Text="Язык описаний слухов" Style="{StaticResource AppLabel}"/>
                            <ComboBox x:Name="RumorLanguageCombo" Width="260" HorizontalAlignment="Left" Style="{StaticResource AppComboBox}">
                                <ComboBoxItem Tag="ru">Русский</ComboBoxItem>
                                <ComboBoxItem Tag="en">English</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="MarketSectionText" Text="Рынок и конвертация" Style="{StaticResource AppSectionTitle}"/>
                        <TextBlock x:Name="LeagueLabel" Text="Лига" Style="{StaticResource AppLabel}" Margin="0,12,0,5"/>
                        <ComboBox x:Name="LeagueCombo" Style="{StaticResource AppComboBox}"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="ThresholdLabel" Text="Переходить к дивайнам при сумме" Style="{StaticResource AppLabel}"/>
                                <TextBox x:Name="ThresholdBox" Style="{StaticResource AppTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="ThresholdCurrencyLabel" Text="Единица порога" Style="{StaticResource AppLabel}"/>
                                <ComboBox x:Name="ThresholdCurrencyCombo" Style="{StaticResource AppComboBox}">
                                    <ComboBoxItem Tag="divine">Дивайны</ComboBoxItem>
                                    <ComboBoxItem Tag="exalted">Экзальты</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCard}">
                    <StackPanel>
                        <TextBlock x:Name="ServiceSectionText" Text="Обновление и логи" Style="{StaticResource AppSectionTitle}"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="RefreshIntervalLabel" Text="Автообновление, минут (15–240)" Style="{StaticResource AppLabel}"/>
                                <TextBox x:Name="RefreshIntervalBox" Style="{StaticResource AppTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="LogLevelLabel" Text="Уровень логирования" Style="{StaticResource AppLabel}"/>
                                <ComboBox x:Name="LogLevelCombo" Style="{StaticResource AppComboBox}">
                                    <ComboBoxItem Tag="error">Только ошибки</ComboBoxItem>
                                    <ComboBoxItem Tag="warning">Предупреждения</ComboBoxItem>
                                    <ComboBoxItem Tag="info">Обычный</ComboBoxItem>
                                    <ComboBoxItem Tag="debug">Отладочный</ComboBoxItem>
                                    <ComboBoxItem Tag="trace">Трассировочный</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="LogHintText"
                                   Text="Debug/Trace пишутся в папку logs рядом с приложением; кнопка «Открыть логи» есть в главном окне. Файлы ротируются автоматически."
                                   Style="{StaticResource AppMutedText}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ValidationText" Foreground="{StaticResource DangerBrush}" FontSize="12.5"
                           TextWrapping="Wrap" Margin="2,10,2,0"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ResetButton" Grid.Column="0" Content="Сбросить общие настройки"
                    Style="{StaticResource DangerButton}" Click="ResetButton_Click"/>
            <Button x:Name="CancelButton" Grid.Column="2" Content="Отмена"
                    Style="{StaticResource AppButton}" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Grid.Column="4" Content="Сохранить"
                    Style="{StaticResource PrimaryButton}" Click="SaveButton_Click"/>
        </Grid>
    </Grid>
</mah:MetroWindow>
