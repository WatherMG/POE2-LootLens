<mah:MetroWindow x:Class="Poe2LootLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        FontFamily="{DynamicResource AppFontFamily}"
        Title="POE2 LootLens"
        Width="860" Height="650"
        MinWidth="780" MinHeight="600"
        MaxHeight="760"
        Icon="app.ico"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        BorderBrush="#283143"
        WindowTitleBrush="#181D26"
        NonActiveWindowTitleBrush="#181D26"
        TitleForeground="#C5CEDA"
        GlowBrush="#303845"
        TitleCharacterCasing="Normal"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0E1520" BorderBrush="#253147" BorderThickness="0,0,0,1" Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="46" Height="46" CornerRadius="12" Background="#184778" BorderBrush="#4C9BE8" BorderThickness="1">
                    <TextBlock Text="L" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="20" FontWeight="Bold" Foreground="#D9EEFF"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="AppTitleText" Text="POE2 LootLens" FontSize="19" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="AppSubtitleText" Text="Оценка наград и сканирование слухов Атласа"
                               Style="{StaticResource AppMutedText}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusPill" CornerRadius="13" Background="#102A24" BorderBrush="#225B49"
                            BorderThickness="1" Padding="10,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="#56D69A" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusPillText" Text="ГОТОВ" Foreground="#56D69A"
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="GeneralSettingsButton" Content="⚙  Настройки" Style="{StaticResource AppButton}"
                            Padding="12,7" Click="GeneralSettingsButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,14,20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AppCard}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="DataTitleText" Text="Данные рынка" Style="{StaticResource AppSectionTitle}"/>
                        <TextBlock x:Name="StatusLabel" Text="Загрузка данных…" Style="{StaticResource AppMutedText}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="LeagueSummaryLabel" Text="Лига: Runes of Aldur" Foreground="#C8D4E4" FontSize="12.5" Margin="0,3,0,0"/>
                        <TextBlock x:Name="RefreshDataCooldownLabel" Text="Автообновление каждые 30 минут"
                                   Foreground="#74849B" FontSize="11.5" Margin="0,3,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#102B47" BorderBrush="#3A8EDC" BorderThickness="1"
                            CornerRadius="10" Padding="13,9" Margin="18,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image x:Name="DivineRateIconImage" Width="28" Height="28" Margin="0,0,9,0" Stretch="Uniform"/>
                            <StackPanel>
                                <TextBlock x:Name="RateValueLabel" Text="1 див. = — экз." FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="RateSourceLabel" Text="Источник: poe.ninja" Foreground="#90AAC4" FontSize="10.5"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Grid.Column="2" x:Name="RefreshDataButton" Content="Обновить данные"
                            Style="{StaticResource AppButton}" VerticalAlignment="Center" Click="RefreshDataButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppCard}" BorderBrush="#315377" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="PriceModuleTitleText" Text="Оценщик комбинаций" Style="{StaticResource AppSectionTitle}"/>
                                <TextBlock x:Name="PriceModuleDescriptionText"
                                           Text="Распознаёт награды в выбранной области и показывает их стоимость поверх игры."
                                           Style="{StaticResource AppMutedText}" Margin="0,5,12,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="PriceSettingsButton" Content="⚙" Width="40" Height="38"
                                    ToolTip="Настройки оценщика" Style="{StaticResource AppButton}" Padding="0"
                                    Click="PriceSettingsButton_Click"/>
                        </Grid>

                        <Border Grid.Row="1" Background="#0E1723" BorderBrush="#263850" BorderThickness="1"
                                CornerRadius="9" Padding="12,10" Margin="0,15,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="PriceAreaLabelText" Text="Область захвата" Foreground="#8FA1B8" FontSize="11.5"/>
                                    <TextBlock x:Name="RegionLabel" Text="Не настроена" Foreground="White" FontSize="13.5" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="PriceStatusDot" Width="8" Height="8" Fill="#75849A" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PriceModuleStatusText" Text="Остановлен" Foreground="#A7B5C8" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="2" x:Name="PriceHotkeySummaryText" Text="Хоткеи отключены"
                                   Foreground="#74849B" FontSize="11.5" Margin="0,12,0,0"
                                   VerticalAlignment="Top" TextWrapping="Wrap"/>

                        <Grid Grid.Row="3" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="PriceGuideButton" Content="i" ToolTip="Как правильно выделить область"
                                    Style="{StaticResource AppButton}" FontWeight="Bold" FontSize="16" Padding="0"
                                    Click="PriceGuideButton_Click"/>
                            <Button Grid.Column="2" x:Name="CalibrateButton" Content="Выбрать область"
                                    Style="{StaticResource AppButton}" Click="CalibrateButton_Click"/>
                            <Button Grid.Column="4" x:Name="StartStopButton" Content="Запустить"
                                    Style="{StaticResource PrimaryButton}" Click="StartStopButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource AppCard}" BorderBrush="#315377" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="RumorModuleTitleText" Text="Сканер слухов" Style="{StaticResource AppSectionTitle}"/>
                                <TextBlock x:Name="RumorModuleDescriptionText"
                                           Text="Анализирует слухи островов, сохраняет историю и сортирует находки по важности."
                                           Style="{StaticResource AppMutedText}" Margin="0,5,12,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="RumorSettingsButton" Content="⚙" Width="40" Height="38"
                                    ToolTip="Настройки сканера слухов" Style="{StaticResource AppButton}" Padding="0"
                                    Click="RumorSettingsButton_Click"/>
                        </Grid>

                        <Border Grid.Row="1" Background="#0E1723" BorderBrush="#263850" BorderThickness="1"
                                CornerRadius="9" Padding="12,10" Margin="0,15,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="RumorModeCaptionText" Text="Режим" Foreground="#8FA1B8" FontSize="11.5"/>
                                    <TextBlock x:Name="RumorModeLabel" Text="Ручной" Foreground="White" FontSize="13.5" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="RumorStatusDot" Width="8" Height="8" Fill="#75849A" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RumorModuleStatusText" Text="Остановлен" Foreground="#A7B5C8" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2" Margin="0,12,0,0">
                            <TextBlock x:Name="RumorHotkeySummaryText" Text="Ручной хоткей: не назначен"
                                       Foreground="#74849B" FontSize="11.5" TextWrapping="Wrap"/>
                            <TextBlock x:Name="RumorScannerStatusLabel" Text="Сканер выключен"
                                       Foreground="#92A2B8" FontSize="11.5" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>

                        <Grid Grid.Row="3" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="ManualRumorScanButton" Content="Сканировать сейчас"
                                    Style="{StaticResource AppButton}" Visibility="Collapsed"
                                    Click="ManualRumorScanButton_Click"/>
                            <Button Grid.Column="2" x:Name="ToggleRumorScannerButton" Content="Запустить"
                                    Style="{StaticResource PrimaryButton}" Click="ToggleRumorScannerButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#0D131D" BorderBrush="#263147" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <TextBlock x:Name="VersionLabel" Text="v0.9.0-beta.11" Foreground="#708199" FontSize="11.5" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="OpenLogsButton" Content="Открыть логи" Style="{StaticResource AppButton}"
                            Padding="12,6" MinHeight="34" Margin="0,0,8,0" Click="OpenLogsButton_Click"/>
                    <Button x:Name="TelegramButton" Content="Обратная связь" Style="{StaticResource AppButton}"
                            Padding="12,6" MinHeight="34" Margin="0,0,8,0" Click="TelegramButton_Click"/>
                    <Button x:Name="SupportButton" Content="Поддержать" Style="{StaticResource PrimaryButton}"
                            Padding="12,6" MinHeight="34" Click="SupportButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
